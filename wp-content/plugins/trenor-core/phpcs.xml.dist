<?xml version="1.0"?>
<ruleset name="Trenor Core">
  <description>PHPCS rules for trenor-core</description>
  <file>trenor-core.php</file>
  <file>src</file>
  <file>tests</file>
  <arg name="basepath" value="."/>
  <arg name="extensions" value="php"/>
  <rule ref="WordPress-Core"/>
  <rule ref="WordPress-Extra"/>
  <rule ref="WordPress-Docs"/>
  <rule ref="PSR12"/>
  <exclude-pattern>vendor/*</exclude-pattern>
</ruleset>
