{
  "name": "dennicka/trenor-core",
  "description": "Core domain plugin for Smetaonline",
  "type": "wordpress-plugin",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpstan/phpstan": "^1.12",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Trenor\\Core\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Trenor\\Core\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "php -l trenor-core.php && find src tests -name '*.php' -print0 | xargs -0 -n1 php -l",
    "phpcs": "bash scripts/phpcs-changed.sh",
    "phpcs:full": "phpcs",
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "license": "proprietary"
}
